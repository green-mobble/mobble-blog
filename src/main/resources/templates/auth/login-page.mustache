<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <title>로그인</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/css/common.css" />
    <link rel="stylesheet" href="/css/header.css" />
    <link rel="stylesheet" href="/css/footer.css" />
    <link rel="stylesheet" href="/css/auth.css" />
    <link rel="stylesheet" href="/css/login.css" />
  </head>
  <body>
    <header>
      <div class="header-inner">
        <button class="logo">Logo Area</button>
        <button class="join-btn" onclick="location.href='/join-form'">
          JoinBtn Area
        </button>
      </div>
    </header>

    <main>
      <div class="auth-content">
        <section class="auth-left">
          <h1>Lorem Ipsum</h1>
          <p>
            Lorem ipsum dolor sit amet consectetur. Viverra id lacinia nisl
            fringilla eget a. Est habitasse mattis penatibus turpis feugiat.
            Eget sed nibh dui proin leo amet etiam.
          </p>
        </section>

        <aside class="auth-right">
          <h3>로그인</h3>
          <form class="auth-form" action="#" method="post">
            <div class="form-group">
              <input
                type="text"
                name="username"
                placeholder="아이디"
                required
              />
            </div>
            <div class="form-group">
              <input
                type="password"
                name="password"
                placeholder="비밀번호"
                required
              />
            </div>
            <button type="submit" class="auth-submit">LogIn</button>
          </form>
          <div class="auth-subtext">
            아직 계정이 없으신가요? <a href="/join-form">회원가입</a>
          </div>
        </aside>
      </div>
    </main>

    <footer>
      <div class="footer-inner">© Footer Content</div>
    </footer>
  </body>
</html>
